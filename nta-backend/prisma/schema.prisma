// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// A single exam question
model Question {
  id           Int        @id @default(autoincrement())
  subject      String     @default("Physics")
  topic        String
  questionText String     @db.Text
  diagramType  String?
  diagramSvg   String?    @db.Text
  correctOption Int       // 1, 2, 3, or 4
  createdAt    DateTime   @default(now())

  options      Option[]
  responses    Response[]
}

// Four answer options per question
model Option {
  id           Int      @id @default(autoincrement())
  questionId   Int
  optionNumber Int      // 1, 2, 3, or 4
  optionText   String   @db.Text

  question     Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([questionId, optionNumber])
}

// A candidate (exam-taker) session
model Candidate {
  id          Int      @id @default(autoincrement())
  name        String
  rollNumber  String
  examSet     String   @default("SET-A")
  createdAt   DateTime @default(now())

  attempts    ExamAttempt[]
}

// One exam attempt per candidate
model ExamAttempt {
  id                 Int       @id @default(autoincrement())
  candidateId        Int
  startedAt          DateTime  @default(now())
  submittedAt        DateTime?
  timeTakenSecs      Int?
  totalAnswered      Int       @default(0)
  totalMarkedReview  Int       @default(0)
  totalNotAnswered   Int       @default(0)
  status             String    @default("in-progress") // in-progress | submitted

  candidate          Candidate   @relation(fields: [candidateId], references: [id])
  responses          Response[]
}

// Each response = one question answered in an attempt
model Response {
  id             Int      @id @default(autoincrement())
  attemptId      Int
  questionId     Int
  selectedOption Int?     // 1, 2, 3, or 4 — null if not answered
  status         String   // not-visited | not-answered | answered | marked | answered-marked
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  attempt        ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question       Question    @relation(fields: [questionId], references: [id])

  @@unique([attemptId, questionId])
}

// Admin Users for Admin Panel
model Admin {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}
